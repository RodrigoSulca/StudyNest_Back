# Puerto del servidor
PORT=4000

# Origen permitido para CORS (frontend Vite)
CORS_ORIGIN=http://localhost:5173

# Base de datos (opcional). Si no se define DATABASE_URL, el modulo de
# Notificaciones y Eventos usa un almacen en memoria para poder correr
# el proyecto sin PostgreSQL instalado.
# DATABASE_URL=postgresql://usuario:password@localhost:5432/studynest

# Envio de correo (Nodemailer). Si no se configuran, se usa un transporte
# "mock" que solo registra el correo en consola (util para desarrollo/demo).
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=tu_correo@gmail.com
# SMTP_PASS=tu_password_de_aplicacion
# SMTP_FROM="StudyNest <no-reply@studynest.com>"
