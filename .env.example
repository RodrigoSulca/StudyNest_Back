PORT=3001
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=studynest
DB_USER=postgres
DB_PASSWORD=

# JWT
JWT_SECRET=change_me
JWT_EXPIRATION=7d

# CORS
CORS_ORIGIN=http://localhost:5173

# Validación de imágenes con IA (CLIP local vía transformers.js - SIN token)
# El modelo se descarga una sola vez a .ia-cache/ y luego corre offline.
IA_MODELO=Xenova/clip-vit-base-patch32
# Umbral mínimo de confianza (0..1) para aprobar automáticamente una imagen
IA_UMBRAL_CONFIANZA=0.5
